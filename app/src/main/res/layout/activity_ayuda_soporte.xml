<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@null"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/ayuda_y_soporte"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />

            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />

        </LinearLayout>

        <!-- Título preguntas -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/preguntas_frecuentes"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- FAQ 1 -->
        <LinearLayout
            android:id="@+id/faq1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/FondoGris"
            android:padding="14dp"
            android:layout_marginBottom="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/c_mo_puedo_seguir_mi_progreso"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/arrow_down_float" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/accede_al_panel_de_control_para_ver_tu_estado_f_sico_completo_incluyendo_masa_muscular_definici_n_simetr_a_y_actividad_semanal_tambi_n_puedes_a_adir_mediciones_desde_la_pantalla_de_inicio_con_el_bot_n"
                android:textColor="@color/GrisTexto"
                android:textSize="13sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- FAQ 2 -->
        <LinearLayout
            android:id="@+id/faq2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/FondoGris"
            android:padding="14dp"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/puedo_sincronizar_con_otras_aplicaciones"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/arrow_down_float" />

        </LinearLayout>

        <!-- FAQ 3 -->
        <LinearLayout
            android:id="@+id/faq3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/FondoGris"
            android:padding="14dp"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/c_mo_cancelo_mi_suscripci_n"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/arrow_down_float" />

        </LinearLayout>

        <!-- FAQ 4 -->
        <LinearLayout
            android:id="@+id/faq4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/FondoGris"
            android:padding="14dp"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/c_mo_restablezco_mi_contrase_a"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/arrow_down_float" />

        </LinearLayout>

        <!-- FAQ 5 -->
        <LinearLayout
            android:id="@+id/faq5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/FondoGris"
            android:padding="14dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/est_n_seguros_mis_datos"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/arrow_down_float" />

        </LinearLayout>

        <!-- Ponerse en contacto -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ponerse_en_contacto"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Botón contactar soporte -->
        <Button
            android:id="@+id/btnContactarSoporte"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/contactar_con_soporte_t_cnico"
            android:backgroundTint="@color/background"
            android:textColor="@color/ColorPrincipal"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"
            style="@style/Widget.AppCompat.Button.Borderless" />

        <!-- Botón foro -->
        <Button
            android:id="@+id/btnForo"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/nase_al_foro_de_la_comunidad"
            android:backgroundTint="@color/background"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            style="@style/Widget.AppCompat.Button.Borderless" />

        <!-- Footer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/camine_pal_gym_2"
                android:textColor="@color/GrisTexto"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/versi_n_1_0"
                android:textColor="@color/GrisTexto"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/_2025_cpg_inc_all_rights_reserved"
                android:textColor="@color/GrisTexto"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>