<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@null"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/mi_carrito"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />

            <View android:layout_width="40dp" android:layout_height="40dp" />

        </LinearLayout>

        <!-- Carrito vacío -->
        <TextView
            android:id="@+id/tvCarritoVacio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tu carrito está vacío 🛒"
            android:textColor="@color/GrisTexto"
            android:textSize="16sp"
            android:gravity="center"
            android:paddingVertical="40dp"
            android:visibility="gone"/>

        <!-- Recycler Productos -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerCarrito"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="16dp" />

        <!-- Código descuento -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/FondoGris"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/codigo_de_descuento"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/inputCodigo"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:hint="@string/ingrese_c_digo"
                    android:textColor="@android:color/white"
                    android:textColorHint="@color/GrisTexto"
                    android:background="@color/background"
                    android:padding="10dp"
                    android:inputType="textCapCharacters"/>

                <Button
                    android:id="@+id/btnAplicar"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:text="@string/aplicar"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="@color/ColorPrincipal"
                    android:textColor="@color/background" />

            </LinearLayout>

        </LinearLayout>

        <!-- Resumen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/FondoGris"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/resumen_de_orden"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Subtotal -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/subtotal"
                    android:textColor="@color/GrisTexto"
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/tvSubtotalValor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$ 0"
                    android:textColor="@color/white"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Descuento -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Descuento"
                    android:textColor="@color/GrisTexto"
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/tvDescuentoValor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$ 0"
                    android:textColor="@color/ColorPrincipal"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Envío -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/env_o_gratis"
                    android:textColor="@color/GrisTexto"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GRATIS"
                    android:textColor="@color/ColorPrincipal"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/GrisTexto"
                android:layout_marginBottom="10dp"/>

            <!-- Total -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/total"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="18sp"/>
                <TextView
                    android:id="@+id/tvTotalValor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$ 0"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="18sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Botón pagar -->
        <Button
            android:id="@+id/btnPagar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/procede_con_el_pago"
            android:backgroundTint="@color/ColorPrincipal"
            android:textColor="@color/background"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>