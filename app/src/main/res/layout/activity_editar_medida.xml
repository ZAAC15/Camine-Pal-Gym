<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">
    <!-- HEADER FLECHA ATRAS Y TITULO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="8dp">

        <!-- icono Flecha hacia atras -->
        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/white"
            android:contentDescription="@string/atr_s"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/editar_medida"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:fontFamily="sans-serif-bold" />
    </LinearLayout>

    <!-- Subtitulo instrucciOn -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/ingresa_tus_medidas_corporales_correspondientes"
        android:textColor="@color/GrisTexto"
        android:textSize="13sp"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="24dp" />

    <!-- SCROLL CON FORMULARIO  -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <!-- CAMPO: ALTURA -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilAltura"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:boxBackgroundColor="#1E1E1E"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/FondoGris"
                app:hintTextColor="@color/GrisTexto"
                app:startIconDrawable="@android:drawable/ic_menu_sort_by_size"
                app:startIconTint="@color/GrisTexto"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAltura"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/altura_cm"
                    android:inputType="numberDecimal"
                    android:textColor="@color/white"
                    android:textColorHint="@color/GrisTexto"
                    android:backgroundTint="@android:color/transparent"
                    android:paddingVertical="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- CAMPO PESO -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPeso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:boxBackgroundColor="@color/Gris2"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/FondoGris"
                app:hintTextColor="@color/GrisTexto"
                app:startIconDrawable="@android:drawable/ic_menu_info_details"
                app:startIconTint="@color/GrisTexto"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <!-- icono ic_monitor_weight o ic_fitness_center (balanza/peso) -->
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPeso"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/peso_kg"
                    android:inputType="numberDecimal"
                    android:textColor="@color/white"
                    android:textColorHint="@color/GrisTexto"
                    android:backgroundTint="@android:color/transparent"
                    android:paddingVertical="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- CAMPO EDAD -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEdad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:boxBackgroundColor="@color/Gris2"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/FondoGris"
                app:hintTextColor="@color/GrisTexto"
                app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                app:startIconTint="@color/GrisTexto"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <!-- icono ic_calendar_today o ic_event (calendario) -->
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEdad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/edad"
                    android:inputType="number"
                    android:textColor="@color/white"
                    android:textColorHint="@color/GrisTexto"
                    android:backgroundTint="@android:color/transparent"
                    android:paddingVertical="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- PORCENTAJE DE GRASA -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilGrasa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:boxBackgroundColor="@color/Gris2"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/FondoGris"
                app:hintTextColor="@color/GrisTexto"
                app:startIconDrawable="@android:drawable/ic_menu_sort_by_size"
                app:startIconTint="@color/GrisTexto"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <!-- icono ic_percent o signo % -->
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etGrasa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/porcentaje_de_grasa"
                    android:inputType="numberDecimal"
                    android:textColor="@color/white"
                    android:textColorHint="@color/GrisTexto"
                    android:backgroundTint="@android:color/transparent"
                    android:paddingVertical="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Link "Si no conoces tu porcentaje de grasa Ingresa aca" -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/si_no_conoces_tu_porcentaje_de_grasa"
                    android:textColor="@color/GrisTexto"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvLinkGrasa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ingresa_aca"
                    android:textColor="@color/ColorPrincipal"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>

            <!-- SEXO BIOLÓGICO-->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSexo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:boxBackgroundColor="@color/Gris2"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/FondoGris"
                app:hintTextColor="@color/GrisTexto"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                |<AutoCompleteTextView
                    android:id="@+id/actvSexo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/sexo_biologico"
                    android:textColor="@color/white"
                    android:textColorHint="@color/GrisTexto"
                    android:backgroundTint="@android:color/transparent"
                    android:paddingVertical="16dp"
                    android:inputType="none"
                    android:focusable="false"
                    android:focusableInTouchMode="false" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- TIPO DE CUERPO -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTipoCuerpo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:boxBackgroundColor="@color/Gris2"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/FondoGris"
                app:hintTextColor="@color/GrisTexto"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                <AutoCompleteTextView
                    android:id="@+id/actvTipoCuerpo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/tipo_de_cuerpo"
                    android:textColor="@color/white"
                    android:textColorHint="@color/GrisTexto"
                    android:backgroundTint="@android:color/transparent"
                    android:paddingVertical="16dp"
                    android:inputType="none"
                    android:focusable="false"
                    android:focusableInTouchMode="false" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Link "Si no conoces tu tipo de cuerpo Ingresa aca" -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/si_no_conoces_tu_tipo_de_cuerpo"
                    android:textColor="@color/GrisTexto"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvLinkTipoCuerpo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ingresa_aca"
                    android:textColor="#F5C518"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>

            <!-- NIVEL DE CONDICION FISICA  -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNivelCondicion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:boxBackgroundColor="@color/Gris2"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/FondoGris"
                app:hintTextColor="@color/GrisTexto"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                <AutoCompleteTextView
                    android:id="@+id/actvNivelCondicion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/nivel_de_condici_n_f_sica"
                    android:textColor="@color/white"
                    android:textColorHint="@color/GrisTexto"
                    android:backgroundTint="@android:color/transparent"
                    android:paddingVertical="16dp"
                    android:inputType="none"
                    android:focusable="false"
                    android:focusableInTouchMode="false" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BOTON GUARDAR MEDIDAS (FIJO ABAJO) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="28dp"
        android:background="@color/FondoGris">

        <Button
            android:id="@+id/btnGuardarMedidas"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/guardar_medidas"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:fontFamily="sans-serif-bold"
            android:backgroundTint="@color/ColorPrincipal"
            android:stateListAnimator="@null"
            app:cornerRadius="28dp" />
    </LinearLayout>
</LinearLayout>