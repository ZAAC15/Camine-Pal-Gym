<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/white"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/estado_corporal"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:fontFamily="sans-serif-bold" />
        </LinearLayout>

        <!-- Card Overall Score -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/FondoGris"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/overall_fitness_score"
                        android:textColor="@color/GrisTexto"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="36sp"
                            android:fontFamily="sans-serif-bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/_100"
                            android:textColor="@color/GrisTexto"
                            android:textSize="14sp"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPuntosScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sin racha aún"
                        android:textColor="@color/ColorVerde"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Círculo score -->
                <TextView
                    android:id="@+id/tvScoreCirculo"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-bold"
                    android:gravity="center"
                    android:background="@drawable/bg_circulo_score" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Masa corporal + Definición -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Masa corporal -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/FondoGris"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/masa_corporal"
                        android:textColor="@color/GrisTexto"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvMasaCorporal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- kg"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Barras BMI -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <View android:id="@+id/barraBmi1"
                            android:layout_width="0dp" android:layout_height="6dp"
                            android:layout_weight="1" android:background="@color/background"
                            android:layout_marginEnd="3dp" />
                        <View android:id="@+id/barraBmi2"
                            android:layout_width="0dp" android:layout_height="6dp"
                            android:layout_weight="1" android:background="@color/background"
                            android:layout_marginEnd="3dp" />
                        <View android:id="@+id/barraBmi3"
                            android:layout_width="0dp" android:layout_height="6dp"
                            android:layout_weight="1" android:background="@color/background"
                            android:layout_marginEnd="3dp" />
                        <View android:id="@+id/barraBmi4"
                            android:layout_width="0dp" android:layout_height="6dp"
                            android:layout_weight="1" android:background="@color/background" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:text="Bajo"
                            android:textColor="@color/GrisTexto" android:textSize="9sp"
                            android:gravity="center" />
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:text="Normal"
                            android:textColor="@color/GrisTexto" android:textSize="9sp"
                            android:gravity="center" />
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:text="Sobre"
                            android:textColor="@color/GrisTexto" android:textSize="9sp"
                            android:gravity="center" />
                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:text="Obeso"
                            android:textColor="@color/GrisTexto" android:textSize="9sp"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Definición -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@color/FondoGris"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/definici_n"
                        android:textColor="@color/GrisTexto"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvDefinicionCirculo"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:text="--"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:gravity="center"
                            android:background="@drawable/bg_circulo_score"
                            android:layout_marginEnd="10dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDefLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sin datos"
                                android:textColor="@color/GrisTexto"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-bold" />

                            <TextView
                                android:id="@+id/tvDefSub"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Agrega % de grasa"
                                android:textColor="@color/GrisTexto"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Simetría + Volumen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Simetría -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/FondoGris"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/simetr_a"
                        android:textColor="@color/GrisTexto"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvSimetria"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-bold"
                        android:layout_marginBottom="6dp" />

                    <ProgressBar
                        android:id="@+id/progressSimetria"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:progress="0"
                        android:progressTint="@color/ColorPrincipal"
                        android:progressBackgroundTint="@color/background" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Basado en nivel y BMI"
                        android:textColor="@color/GrisTexto"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Volumen / Masa magra -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@color/FondoGris"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Masa magra"
                        android:textColor="@color/GrisTexto"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvVolumen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- kg"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-bold"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Peso - grasa corporal"
                        android:textColor="@color/GrisTexto"
                        android:textSize="10sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Consistencia -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/FondoGris"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/consistencia"
                        android:textColor="@color/GrisTexto"
                        android:textSize="12sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_fire"
                        app:tint="@color/Naranja" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvConsistencia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sin racha aún"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Completa ejercicios diariamente para mantener tu racha activa"
                    android:textColor="@color/GrisTexto"
                    android:textSize="12sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>