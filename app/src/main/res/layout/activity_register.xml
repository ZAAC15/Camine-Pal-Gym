<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_register"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingEnd="22dp"
    android:paddingTop="18dp"
    android:paddingBottom="18dp"
    android:gravity="center_horizontal">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:id="@+id/imgLogoRegister"
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:src="@drawable/iconoregister"
            android:contentDescription="@string/Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/registrarse"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="24sp" />

    </LinearLayout>



    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="2dp">

                <EditText
                    android:id="@+id/edtUsuario"
                    android:layout_width="320dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_input_dark"
                    android:hint="@string/usuario"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#7D7D7D"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/edtCorreo"
                    android:layout_width="320dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_input_dark"
                    android:hint="@string/correo"
                    android:inputType="textEmailAddress"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#7D7D7D"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/edtCelular"
                    android:layout_width="320dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_input_dark"
                    android:hint="@string/celular"
                    android:inputType="phone"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#7D7D7D"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textSize="15sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="320dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#7D7D7D"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtPassword"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input_dark"
                        android:hint="@string/contrase_a"
                        android:inputType="textPassword"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#7D7D7D"
                        android:paddingStart="18dp"
                        android:paddingEnd="50dp"
                        android:textSize="15sp" />

                </com.google.android.material.textfield.TextInputLayout>


                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="320dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#7D7D7D"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtPassword2"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input_dark"
                        android:hint="@string/verificar_contrase_a"
                        android:inputType="textPassword"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#7D7D7D"
                        android:paddingStart="18dp"
                        android:paddingEnd="50dp"
                        android:textSize="15sp" />

                </com.google.android.material.textfield.TextInputLayout>


                <CheckBox
                    android:id="@+id/checkTyC"
                    android:layout_width="320dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/tyc"
                    android:textColor="#BDBDBD"
                    android:textSize="13sp"
                    android:buttonTint="#FFFFFF" />


            </LinearLayout>

            <Button
                android:id="@+id/btnRegistrar"
                android:layout_width="320dp"
                android:layout_height="52dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_button_yellow"
                android:text="@string/registrarse"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="16sp"
                app:backgroundTint="@null" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="@string/ya_tienes_una_cuenta"
                    android:textColor="#FFD600"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/txtIrLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Inicia Sesion"
                    android:textColor="#FFD600"
                    android:textStyle="bold"
                    android:textSize="14sp" />

            </LinearLayout>


        </LinearLayout>
    </ScrollView>

</LinearLayout>