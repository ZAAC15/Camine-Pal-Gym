<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@null"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tema"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Color de acento -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/color_de_acento"
            android:textColor="@color/GrisTexto"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/FondoGris"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Dorado -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/colorDorado"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_color_dorado"
                        android:src="@android:drawable/checkbox_on_background"
                        android:padding="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dorado"
                        android:textColor="@color/GrisTexto"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Azul -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/colorAzul"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_color_azul" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/azul"
                        android:textColor="@color/GrisTexto"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Verde -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/colorVerde"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_color_verde" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/verde"
                        android:textColor="@color/GrisTexto"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Morado -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/colorMorado"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_color_morado" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/morado"
                        android:textColor="@color/GrisTexto"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Naranja -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/colorNaranja"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_color_naranja" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/naranja"
                        android:textColor="@color/GrisTexto"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- Rojo -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/colorRojo"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_color_rojo" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/rojo"
                        android:textColor="@color/GrisTexto"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Tamaño de fuente -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tama_o_de_la_fuente"
            android:textColor="@color/GrisTexto"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/FondoGris"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnSmall"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/small"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/background"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnMedium"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/medium"
                    android:textColor="@color/background"
                    android:backgroundTint="@color/ColorPrincipal"
                    android:layout_marginHorizontal="4dp" />

                <Button
                    android:id="@+id/btnLarge"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/largo"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/background"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tama_o_default_de_la_fuente"
                android:textColor="@color/GrisTexto"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>