<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/FondoGris"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">

        <!-- ========== HEADER ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTituloApp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/estado_fisico"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />

            <!-- Avatar / Iniciales del usuario -->
            <!-- IMAGEN: Círculo con iniciales "US" - usa un ImageView o TextView circular -->
            <TextView
                android:id="@+id/tvUserAvatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="@string/us"
                android:textColor="@color/FondoGris"
                android:textSize="12sp"
                android:fontFamily="sans-serif-bold"
                android:gravity="center"
                android:background="@drawable/bg_avatar_circle"
                android:layout_marginEnd="12dp" />

            <!-- Icono campana de notificaciones -->
            <!-- ICONO: ic_notifications_outline o similar de Material Icons -->
            <ImageView
                android:id="@+id/ivNotificaciones"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_notifications"
                android:contentDescription="@string/notificaciones"
                app:tint="@color/white" />
        </LinearLayout>

        <!-- Saludo y fecha -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/tvSaludo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/buenos_dias_usuario"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:fontFamily="sans-serif-bold" />

            <TextView
                android:id="@+id/tvFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/martes_febrero_66"
                android:textColor="@color/GrisTexto"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- ========== CARD PLAN DE HOY ========== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPlanHoy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Etiqueta "Plan de hoy" + badge ACTIVO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/plan_de_hoy"
                        android:textColor="@color/white"
                        android:textSize="13sp" />

                    <!-- Badge ACTIVO -->
                    <TextView
                        android:id="@+id/tvBadgeActivo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/activo"
                        android:textColor="@color/black"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-bold"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/bg_badge_yellow" />
                </LinearLayout>

                <!-- Contenido del plan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- ICONO: Rayo/bolt amarillo en fondo oscuro redondeado -->
                    <ImageView
                        android:id="@+id/ivPlanIcono"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_bolt"
                        app:tint="@color/ColorPrincipal"
                        android:background="@drawable/bg_icon_dark_rounded"
                        android:padding="10dp"
                        android:contentDescription="@string/icono_entrenamiento"
                        android:layout_marginEnd="12dp" />

                    <!-- Nombre y detalles del plan -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvNombrePlan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pecho_y_tricep"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <!-- ICONO: reloj pequeño ic_access_time -->
                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_access_time"
                                app:tint="@color/GrisTexto"
                                android:contentDescription="Duración"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/tvDuracion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/_55_min"
                                android:textColor="@color/GrisTexto"
                                android:textSize="12sp" />

                            <View
                                android:layout_width="4dp"
                                android:layout_height="4dp"
                                android:background="@color/GrisTexto"
                                android:layout_marginHorizontal="8dp" />

                            <TextView
                                android:id="@+id/tvNumEjercicios"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/_6_ejercicios"
                                android:textColor="@color/GrisTexto"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- ICONO: flecha tendencia hacia arriba (ic_trending_up) -->
                    <ImageView
                        android:id="@+id/ivTendencia"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_trending_up"
                        app:tint="@color/ColorPrincipal"
                        android:contentDescription="@string/tendencia" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ========== CARD ESTADO CORPORAL ========== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardEstadoCorporal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estado corporal"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginBottom="16dp" />

                <ImageView
                    android:id="@+id/ivModeloCorporal"
                    android:layout_width="180dp"
                    android:layout_height="260dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_body_model"
                    android:contentDescription="Modelo corporal muscular"
                    android:scaleType="fitCenter" />

                <!-- Leyenda de colores -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp">

                    <!-- Rojo -->
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_dot_red"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Falta trabajo"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginEnd="16dp" />

                    <!-- Amarillo -->
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_badge_yellow"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Moderado"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginEnd="16dp" />

                    <!-- Verde -->
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_color_verde"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fuerte"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ========== CARD MÉTRICAS CLAVE ========== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardMetricas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/metricas_clave"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginBottom="16dp" />

                <!-- Fila de métricas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Peso -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Peso"
                            android:textColor="#888888"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvPeso"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="78"
                            android:textColor="@color/white"
                            android:textSize="26sp"
                            android:fontFamily="sans-serif-bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="kg"
                            android:textColor="#888888"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Divisor vertical -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#333333" />

                    <!-- Altura -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Altura"
                            android:textColor="#888888"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvAltura"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="182"
                            android:textColor="@color/white"
                            android:textSize="26sp"
                            android:fontFamily="sans-serif-bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="cm"
                            android:textColor="#888888"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Divisor vertical -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#333333" />

                    <!-- BMI -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BMI"
                            android:textColor="#888888"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvBMI"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="23.5"
                            android:textColor="@color/white"
                            android:textSize="26sp"
                            android:fontFamily="sans-serif-bold" />

                        <TextView
                            android:id="@+id/tvBMICategoria"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Normal"
                            android:textColor="#43A047"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ========== CARD ESTA SEMANA ========== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardEstaSemana"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header semana + streak -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Esta semana"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-bold" />

                    <!-- ICONO: Fuego (ic_local_fire_department o similar) -->
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_fire"
                        app:tint="#FF6D00"
                        android:contentDescription="Racha"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/tvStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 day streak"
                        android:textColor="#FF6D00"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Días de la semana -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- L - Completado -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_day_active"
                            android:layout_marginHorizontal="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="L"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- M - Completado -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_day_active"
                            android:layout_marginHorizontal="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="M"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- M - Completado -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_day_active"
                            android:layout_marginHorizontal="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="M"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- J - Completado -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_day_active"
                            android:layout_marginHorizontal="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="J"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- V - Completado -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_day_active"
                            android:layout_marginHorizontal="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="V"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- S - Pendiente -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_day_inactive"
                            android:layout_marginHorizontal="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="S"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- D - Pendiente -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_day_inactive"
                            android:layout_marginHorizontal="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="D"
                            android:textColor="@color/GrisTexto"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>