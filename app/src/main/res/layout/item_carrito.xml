<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/FondoGris"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="8dp">

    <!-- Imagen producto -->
    <ImageView
        android:id="@+id/imgCarritoProducto"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:scaleType="centerCrop"
        android:layout_marginEnd="12dp" />

    <!-- Nombre + precio -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvCarritoNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvCarritoPrecio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ColorPrincipal"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Controles cantidad -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Fila +/cantidad/- -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnCarritoMenos"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@color/background"
                android:src="@android:drawable/ic_input_delete"
                android:padding="4dp"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvCarritoCantidad"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />

            <ImageButton
                android:id="@+id/btnCarritoMas"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@color/ColorPrincipal"
                android:src="@android:drawable/ic_input_add"
                android:padding="4dp"
                app:tint="@color/background" />

        </LinearLayout>

        <!-- Eliminar -->
        <ImageButton
            android:id="@+id/btnCarritoEliminar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@null"
            android:src="@android:drawable/ic_menu_delete"
            android:layout_marginTop="6dp"
            app:tint="@color/ColorRojo" />

    </LinearLayout>

</LinearLayout>