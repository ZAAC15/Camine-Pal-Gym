<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/FondoGris">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- HEADER: avatar + nombre + tiempo + menú -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="14sp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/tvUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvTiempo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/GrisTexto"
                    android:textSize="12sp"/>

            </LinearLayout>

            <!-- Badge etiqueta -->
            <TextView
                android:id="@+id/tvEtiqueta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_pro"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:textColor="@color/background"
                android:textSize="10sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- TÍTULO (opcional) -->
        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginTop="10dp"
            android:visibility="gone"/>

        <!-- CONTENIDO -->
        <TextView
            android:id="@+id/tvContenido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginTop="6dp"/>

        <!-- IMAGEN (solo si tiene) -->
        <ImageView
            android:id="@+id/imgPost"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="10dp"
            android:scaleType="centerCrop"
            android:visibility="gone"/>

        <!-- FOOTER: likes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <ImageButton
                android:id="@+id/btnLike"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@null"
                android:src="@android:drawable/btn_star_big_off"
                app:tint="@color/GrisTexto" />

            <TextView
                android:id="@+id/tvLikes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/GrisTexto"
                android:textSize="13sp"
                android:layout_marginStart="4dp"
                android:text="0"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <!-- Botón eliminar (solo visible para el autor) -->
            <ImageButton
                android:id="@+id/btnEliminarPost"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@null"
                android:src="@android:drawable/ic_menu_delete"
                android:visibility="gone"
                app:tint="@color/ColorRojo" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>