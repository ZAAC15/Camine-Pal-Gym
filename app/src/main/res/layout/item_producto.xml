<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    android:backgroundTint="@color/FondoGris">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Imagen + Badge insignia superpuesta -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="150dp">

            <ImageView
                android:id="@+id/img_producto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <!-- Badge de insignia (TOP, NUEVO, OFERTA...) -->
            <TextView
                android:id="@+id/tvInsigniaProducto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="@drawable/bg_badge_pro"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:textColor="@color/background"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Info del producto -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/producto_nombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="14sp"
                android:maxLines="2"
                android:ellipsize="end"/>

            <RatingBar
                android:id="@+id/producto_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:stepSize="0.5"
                android:isIndicator="true"
                android:scaleX="0.7"
                android:scaleY="0.7"
                android:layout_marginStart="-12dp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/producto_precio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ColorPrincipal"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <Button
                android:id="@+id/boton_agregar_producto"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="@string/agregar"
                android:backgroundTint="@color/ColorPrincipal"
                android:textColor="@color/background"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>