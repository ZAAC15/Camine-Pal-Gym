<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@color/FondoGris"
    android:padding="14dp"
    android:layout_marginBottom="8dp">

    <!-- Avatar -->
    <TextView
        android:id="@+id/tvAvatarUsuarioAdmin"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="U"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="sans-serif-bold"
        android:gravity="center"
        android:background="@drawable/bg_avatar_circle"
        android:layout_marginEnd="12dp" />

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNombreUsuarioAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:fontFamily="sans-serif-bold" />

        <TextView
            android:id="@+id/tvCorreoUsuarioAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/GrisTexto"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Rol (toca para cambiar) -->
    <TextView
        android:id="@+id/tvRolUsuarioAdmin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BÁSICO"
        android:textColor="@color/GrisTexto"
        android:textSize="11sp"
        android:fontFamily="sans-serif-bold"
        android:background="@color/background"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp" />

</LinearLayout>